# ─── Required Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.

# OMDB API Key — free at https://www.omdbapi.com/apikey.aspx (1,000 req/day)
OMDB_API_KEY=your_omdb_api_key_here

# Google Gemini API Key — FREE, no credit card needed
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
